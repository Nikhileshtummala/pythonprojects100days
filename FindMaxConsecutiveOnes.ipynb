class Solution:
    def findMaxConsecutiveOnes(self, nums):
        max_ones = 0
        ones = 0
        for i in range (len(nums)):
            if nums [i] == 1:
                ones += 1
            else:
                max_ones = max(max_ones, ones)
                ones = 0
        return max(max_ones, ones)
nums = [1, 1, 0, 1, 1, 1]

sol = Solution()

print(sol.findMaxConsecutiveOnes(nums))
